# ===========================================================================
# OffPay .gitignore
# Only source code and project-approved docs should be committed.
# ===========================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js

# ---------------------------------------------------------------------------
# Expo / React Native
# ---------------------------------------------------------------------------
.expo/
dist/
web-build/
expo-env.d.ts

# Generated native folders (created by prebuild / EAS)
/ios/
/android/

# ---------------------------------------------------------------------------
# Build & bundle output
# ---------------------------------------------------------------------------
*.hbc
*.bundle
*.map

# Metro bundler
.metro-health-check*

# ---------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
invite-codes/
workers/ai-proxy/.dev.vars
workers/ai-proxy/.dev.vars.*
!workers/ai-proxy/.dev.vars.example
workers/api/.dev.vars
workers/api/.dev.vars.*
!workers/api/.dev.vars.example

# Local planning docs
documentation/agentic-payments-system-design.md

# Signing keys & certificates
*.jks
*.p8
*.p12
*.p12
*.key
*.pem
*.mobileprovision
*.keystore

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/

# Test scripts directory
scripts/*
!scripts/verify-client-hardening.js
!scripts/run-all-tests.js
!scripts/generate-invite-codes.js
!scripts/push-invite-worker-secrets.sh
!scripts/push-all-worker-secrets.sh
!scripts/setup-invite-gate.js

# ---------------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# ---------------------------------------------------------------------------
# Debug logs
# ---------------------------------------------------------------------------
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
