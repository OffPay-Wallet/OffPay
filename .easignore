assets/fonts/Geist/ttf/Geist-MediumItalic.ttf
assets/fonts/Geist/ttf/Geist-SemiBoldItalic.ttf
assets/fonts/Geist/ttf/Geist-Thin.ttf
assets/fonts/Geist/ttf/Geist-ThinItalic.ttf
assets/fonts/GeistMono/otf/
assets/fonts/GeistMono/webfonts/
assets/fonts/GeistMono/variable/
