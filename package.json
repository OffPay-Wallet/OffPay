{
  "name": "offpay",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "test": "jest --runInBand",
    "test:all": "node scripts/run-all-tests.js",
    "test:all:coverage": "node scripts/run-all-tests.js --coverage",
    "test:all:android": "node scripts/run-all-tests.js --with-android-export",
    "invite:generate": "node scripts/generate-invite-codes.js",
    "invite:push-worker-secrets": "scripts/push-invite-worker-secrets.sh",
    "invite:setup": "node scripts/setup-invite-gate.js",
    "secrets:push-all": "scripts/push-all-worker-secrets.sh",
    "lint": "expo lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:ai-proxy": "tsc -p workers/ai-proxy/tsconfig.json --noEmit",
    "typecheck:api-worker": "tsc -p workers/api/tsconfig.json --noEmit",
    "deploy:api-worker": "npx wrangler deploy --config workers/api/wrangler.toml",
    "tail:api-worker": "npx wrangler tail --config workers/api/wrangler.toml",
    "verify:hardening": "node scripts/verify-client-hardening.js"
  },
