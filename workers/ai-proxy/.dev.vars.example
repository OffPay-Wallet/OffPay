# Local Cloudflare Worker variables for `wrangler dev`.
# Do not put these values in the Expo app `.env`.

# Optional external chat fallbacks. Workers AI primary uses the wrangler
# [ai] binding and does not need a secret here.
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# Strict privacy gates.
AI_PROXY_PRIVACY_MODE=strict
AI_PROXY_GEMINI_PRIVACY_CONFIRMED=true
AI_PROXY_ALLOW_GEMINI_UNPAID=false
AI_PROXY_ALLOW_VOICE_FALLBACK_WITH_RETENTION=false

# Required for Sarvam-primary voice.
SARVAM_API_KEY=REPLACE_WITH_SARVAM_API_KEY

# Pin voice to a single provider. When set to `sarvam`, both STT and TTS
# use only Sarvam: ElevenLabs is never used as a fallback and an explicit
# `preferredProvider: elevenlabs` is rejected, even if the ElevenLabs
# secrets below are present. Leave unset for legacy Sarvam-first behavior
# with ElevenLabs fallback.
AI_PROXY_VOICE_PROVIDER_LOCK=sarvam

# Optional ElevenLabs fallback (dormant while AI_PROXY_VOICE_PROVIDER_LOCK=sarvam).
ELEVENLABS_API_KEY=REPLACE_WITH_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=REPLACE_WITH_ELEVENLABS_VOICE_ID

# Optional Worker config overrides.
CLOUDFLARE_AI_CHAT_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
CLOUDFLARE_AI_PROVIDER_TIMEOUT_MS=3000
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
AI_PROXY_PRIMARY_PROVIDER_TIMEOUT_MS=8000
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_PROVIDER_TIMEOUT_MS=16000
GROQ_MAX_COMPLETION_TOKENS=4096
GROQ_REASONING_EFFORT=default
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_CODEC=mp3
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_ENABLE_LOGGING=false
AI_PROXY_MAX_CHAT_BYTES=65536
AI_PROXY_MAX_AUDIO_BYTES=8388608
AI_PROXY_MAX_TTS_CHARS=900
AI_PROXY_PROVIDER_TIMEOUT_MS=24000
AI_PROXY_TTS_ENABLED=true
AI_PROXY_RATE_LIMIT_WINDOW_MS=60000
AI_PROXY_RATE_LIMIT_MAX=40

# Session token gate. When `AI_PROXY_REQUIRE_SESSION_TOKEN=true` the
# Worker rejects requests without a valid `x-offpay-ai-session` header
# signed with `AI_PROXY_SESSION_SECRET`. Defaults to `false` for staged
# rollouts so older app builds keep working until the secret is
# distributed to every client.
AI_PROXY_REQUIRE_SESSION_TOKEN=false
AI_PROXY_SESSION_SECRET=REPLACE_WITH_HIGH_ENTROPY_SECRET

# Set this to a comma-separated allowlist only for browser/web clients.
# Example: AI_PROXY_ALLOWED_ORIGINS=https://app.offpay.app,exp://127.0.0.1:8081
AI_PROXY_ALLOWED_ORIGINS=
