# Copy this file to workers/api/.dev.vars for local Worker checks.
# Never commit workers/api/.dev.vars.

NODE_ENV=development
OFFPAY_PROTOTYPE_MODE=true
OFFPAY_ALLOWED_ORIGINS=capacitor://localhost,http://localhost,https://offpay.app
MIN_APP_VERSION=1.0.0
BOOTSTRAP_SECRET_VERSION=1

OFFPAY_ANDROID_PACKAGE_NAME=com.offpay.app
OFFPAY_ANDROID_ATTESTATION_MODE=prototype_bypass
OFFPAY_IOS_BUNDLE_ID=com.offpay.app
OFFPAY_IOS_TEAM_ID=YOUR_APPLE_TEAM_ID

JUPITER_API_BASE_URL=https://api.jup.ag
JUPITER_TRIGGER_API_BASE_URL=https://api.jup.ag/trigger/v2
JUPITER_API_KEY=YOUR_JUPITER_API_KEY

KV_REST_API_URL=https://YOUR_UPSTASH_REDIS_REST_URL
KV_REST_API_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

OFFPAY_BOOTSTRAP_SECRET=REPLACE_WITH_64_HEX_CHARS
OFFPAY_BACKUP_HMAC_SECRET=REPLACE_WITH_DIFFERENT_64_HEX_CHARS

# Required only when OFFPAY_ANDROID_ATTESTATION_MODE=play_integrity.
# GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=play-integrity-sa@YOUR_PROJECT.iam.gserviceaccount.com
# GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

HELIUS_DEVNET_API_KEY=YOUR_HELIUS_DEVNET_API_KEY
HELIUS_MAINNET_API_KEY=YOUR_HELIUS_MAINNET_API_KEY
HELIUS_DEVNET_RPC_URL=https://devnet.helius.xyz/?api-key=YOUR_KEY
HELIUS_MAINNET_RPC_URL=https://mainnet.helius.xyz/?api-key=YOUR_KEY
HELIUS_DEVNET_WS_URL=wss://devnet.helius.xyz/?api-key=YOUR_KEY
HELIUS_MAINNET_WS_URL=wss://mainnet.helius.xyz/?api-key=YOUR_KEY

ALCHEMY_DEVNET_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_MAINNET_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_DEVNET_FALLBACK_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_SECOND_KEY
ALCHEMY_MAINNET_FALLBACK_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_SECOND_KEY
ALCHEMY_PRICE_API_KEY=YOUR_ALCHEMY_PRICE_API_KEY

# Optional only when using a gated/private Umbra indexer or relayer.
# UMBRA_API_KEY=YOUR_UMBRA_API_KEY
UMBRA_INDEXER_URL_MAINNET=https://utxo-indexer.api.umbraprivacy.com
UMBRA_INDEXER_URL_DEVNET=https://utxo-indexer.api-devnet.umbraprivacy.com
UMBRA_RELAYER_URL_MAINNET=https://relayer.api.umbraprivacy.com
UMBRA_RELAYER_URL_DEVNET=https://relayer.api-devnet.umbraprivacy.com
UMBRA_CIRCUIT_VERSION=v3
UMBRA_MIN_SDK_VERSION=3.0.0
UMBRA_LOCAL_TEST_MODE=0

MAGICBLOCK_DEVNET_VALIDATORS=MAS1Dt9qreoRMQ14YQuhg8UTZMMzDdKhmkZMECCzk57,MEUGGrYPxKk17hCr7wpT6s8dtNokZj5U2L57vjYMS8e,MUS3hc9TCw4cGC12vHNoYcCGzJG1txjgQLZWVoeNHNd,MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo
